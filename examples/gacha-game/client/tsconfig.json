{
  "compilerOptions": {
    "target": "ES2022",
    "module": "ESNext",
    "moduleResolution": "Bundler",
    "lib": ["ES2022", "DOM", "DOM.Iterable"],
    "strict": true,
    "esModuleInterop": true,
    "skipLibCheck": true,
    "resolveJsonModule": true,
    "useDefineForClassFields": true,
    "noEmit": true,
    "types": ["vite/client"],
    "baseUrl": ".",
    "paths": {
      "@gacha/summon": ["../packages/summon/src/index.ts"],
      "@gacha/summon/banner": ["../packages/summon/src/banner.ts"]
    }
  },
  "include": ["src/**/*.ts", "../packages/summon/src/**/*.ts"],
  "exclude": ["../packages/summon/src/**/*.test.ts"]
}
