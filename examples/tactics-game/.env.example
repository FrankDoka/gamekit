# Copy to .env and adjust. These mirror the action starter's contract; the GameKit
# toolkit tools read them (tools/src/toolkit-config.ts) when run against this game
# (cwd = this folder, or GAME_ROOT pointed at it).

# Repo root of THIS game the tools operate on. Default: the toolkit repo until set.
GAME_ROOT=

# Asset data bank the DevKit / Asset Bank browses + promotes. Default: <GAME_ROOT>/assets-bank
ASSETS_ROOT=

# Review-metadata store the Asset Bank generates and owns (_review/, _promotion-plans/).
# Default: <ASSETS_ROOT>-metadata. Generated, per-game, gitignored — never copy from another game.
ASSETS_METADATA_ROOT=

# Online host for the DevKit "open online" action. Default: yourgame.example
GAME_ONLINE_HOST=

# Workspace package names the persistence smoke spawns. Defaults: @game/server / @game/client
GAME_SERVER_PACKAGE=
GAME_CLIENT_PACKAGE=

# --- Runtime (server) ---
# PORT the Colyseus server listens on (default 2600). ALLOW_GUEST_LOGIN gates the
# /api/guest endpoint. GAMEKIT_SMOKE_RUN_ID is echoed in the boot log for the
# ownership handshake.
PORT=2600
ALLOW_GUEST_LOGIN=true
GAMEKIT_SMOKE_RUN_ID=
