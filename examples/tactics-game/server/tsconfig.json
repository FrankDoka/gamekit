{
  "compilerOptions": {
    "target": "ES2022",
    "module": "ESNext",
    "moduleResolution": "Bundler",
    "lib": ["ES2022"],
    "strict": true,
    "esModuleInterop": true,
    "skipLibCheck": true,
    "resolveJsonModule": true,
    "experimentalDecorators": true,
    "emitDecoratorMetadata": true,
    "useDefineForClassFields": false,
    "noEmit": true,
    "types": ["node"],
    "baseUrl": ".",
    "paths": {
      "@tactics/turn-grid": ["../packages/turn-grid/src/index.ts"]
    }
  },
  "include": ["src/**/*.ts", "../packages/turn-grid/src/**/*.ts"],
  "exclude": ["../packages/turn-grid/src/**/*.test.ts"]
}
