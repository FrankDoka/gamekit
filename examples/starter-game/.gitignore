# dependencies (each sub-project installs its own, isolated from the toolkit workspace)
node_modules/
server/node_modules/
client/node_modules/

# build output
dist/
client/dist/
*.tsbuildinfo

# capture/screenshot output from the toolkit's capture:zone tool — regenerable, never commit
_capture*/
_v_*/
captures/

# Asset Bank generated, per-game state (created by `pnpm devkit`). Self-populating —
# never commit, never copy from another game. Locations follow toolkit-config's
# ASSETS_ROOT / ASSETS_METADATA_ROOT (defaults below).
assets-bank-metadata/
assets-bank/**/_review/
assets-bank/**/_promotion-plans/
.session-token
.review.lock

# local env (copy .env.example -> .env and fill in)
.env

# generated map manifest is derived from the zone layout via zone:export — keep the
# hand-authored layout, treat the compiled map as regenerable if you re-run export
# (comment the next line out if you prefer to commit the compiled manifest)
# content/maps/*.json
