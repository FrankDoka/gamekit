{
  "name": "@gamekit/toolkit",
  "private": true,
  "version": "0.0.0",
  "type": "module",
  "packageManager": "pnpm@11.7.0",
  "engines": {
    "node": ">=20"
  },
  "description": "Reusable game-dev toolkit: AI-dev orchestration harness, asset bank + DevKit, audio + art pipelines. Game-agnostic; wire a game by implementing @gamekit/game-contract.",
  "scripts": {
    "typecheck": "pnpm -r typecheck",
    "prepare": "git config core.hooksPath .githooks || true",
    "test": "vitest run",
    "validate": "pnpm -r typecheck && pnpm selftest",
    "selftest": "pnpm assets:gate-fixtures && pnpm assets:anim-fixtures && pnpm assets:tint-selftest && pnpm anchors:fixtures && pnpm bank:coverage:selftest && pnpm bank:audit:selftest && pnpm zone:lint:selftest",
    "assets:gate-fixtures": "python tools/asset-cleanup/test_defect_gate_regression.py",
    "assets:anim-fixtures": "python tools/asset-cleanup/test_anim_validators.py",
    "assets:tint-selftest": "python tools/asset-cleanup/test_tint_recolor.py",
    "anchors:fixtures": "python tools/art-pipeline/test_anchor_measure.py",
    "assets:scan": "python tools/asset-cleanup/fringe.py scan",
    "assets:check": "python tools/asset-cleanup/fringe.py check",
    "assets:despill": "python tools/asset-cleanup/fringe.py despill",
    "bank:reconcile": "tsx tools/src/asset-bank-reconcile.ts",
    "bank:coverage:selftest": "tsx tools/src/bank-coverage.ts --selftest",
    "bank:audit:selftest": "tsx tools/src/bank-audit.ts --selftest",
    "create:game": "tsx tools/src/create-game.ts",
    "devkit": "tsx tools/src/devkit.ts",
    "audio:generate": "tsx tools/src/audio-generate.ts",
    "audio:review": "tsx tools/src/audio-review.ts",
    "audio:sync": "node --experimental-strip-types tools/src/audio-sync-client.ts",
    "animation-index": "tsx tools/src/animation-index.ts",
    "animation-promote": "tsx tools/src/animation-promote.ts",
    "frame-picker": "tsx tools/src/frame-picker.ts",
    "capture:tactics": "tsx tools/src/capture-tactics.ts",
    "capture:gacha": "tsx tools/src/capture-gacha.ts",
    "zone:lint:selftest": "tsx tools/src/zone-lint-selftest.ts",
    "docs:budget": "tsx tools/src/docs-budget.ts",
    "sessions:sync": "tsx tools/src/sessions-sync.ts",
    "sessions:check": "tsx tools/src/sessions-sync.ts --check",
    "intake": "tsx tools/src/intake.ts",
    "intake:brief": "tsx tools/src/intake-brief.ts",
    "lane:close": "tsx tools/src/lane-close.ts",
    "lane:recover": "tsx tools/src/lane-recover.ts",
    "lane:spawn": "tsx tools/src/lane-spawn.ts",
    "lanes:board": "tsx tools/src/lanes-board.ts",
    "lanes:watch": "tsx tools/src/lanes-watch.ts",
    "coverage:check": "tsx tools/src/coverage-ratchet.ts",
    "integrator:start": "tsx tools/src/integrator-start.ts",
    "integrator:park": "tsx tools/src/integrator-park.ts",
    "lane:security-scan": "tsx tools/src/lane-security-scan.ts",
    "imagegen:extract": "tsx tools/src/imagegen-extract.ts",
    "capture:zone": "tsx tools/src/capture-zone.ts",
    "lint": "eslint . --max-warnings 300"
  },
  "devDependencies": {
    "@playwright/test": "^1.61.1",
    "@vitest/coverage-v8": "^4.1.9",
    "colyseus.js": "0.16.22",
    "eslint": "^10.6.0",
    "eslint-config-prettier": "^10.1.8",
    "prettier": "^3.9.4",
    "tsx": "^4.19.0",
    "typescript": "^5.6.0",
    "typescript-eslint": "^8.62.1",
    "vitest": "^4.1.9"
  }
}
