{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://gamekit.local/schemas/anchor-sidecar.schema.json",
  "title": "Per-frame animation anchor sidecar",
  "type": "object",
  "additionalProperties": false,
  "required": ["schemaVersion", "sheet", "frameWidth", "frameHeight", "frameCount", "provenance", "frames"],
  "properties": {
    "schemaVersion": { "const": 1 },
    "sheet": { "type": "string", "minLength": 1 },
    "frameWidth": { "type": "integer", "minimum": 1 },
    "frameHeight": { "type": "integer", "minimum": 1 },
    "frameCount": { "type": "integer", "minimum": 1 },
    "provenance": {
      "type": "object",
      "additionalProperties": false,
      "required": ["tool", "measuredAt", "params", "reviewPanel"],
      "properties": {
        "tool": { "type": "string", "minLength": 1 },
        "measuredAt": { "type": "string", "minLength": 1 },
        "params": { "type": "object" },
        "reviewPanel": { "type": "string", "minLength": 1 }
      }
    },
    "frames": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": ["index", "handX", "handY", "headX", "headY"],
        "properties": {
          "index": { "type": "integer", "minimum": 0 },
          "handX": { "type": ["number", "null"] },
          "handY": { "type": ["number", "null"] },
          "headX": { "type": ["number", "null"] },
          "headY": { "type": ["number", "null"] },
          "handReason": { "type": "string" }
        }
      }
    }
  }
}
